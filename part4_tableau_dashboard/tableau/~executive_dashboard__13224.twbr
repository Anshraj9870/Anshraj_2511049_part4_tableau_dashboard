      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_1319706009403393]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1319706009874434]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) - SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1319706009993219]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' default-format='p0.00%' name='[Calculation_1319706012114948]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1319706012667909]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;Fast&quot;&#13;&#10;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN &quot;Normal&quot;&#13;&#10;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;&#13;&#10;END' />
      </column>
